# Infrastructure
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=oa_management
MYSQL_USER=oa_user
MYSQL_PASSWORD=change-me
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=oa_user
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_DEFAULT_VHOST=/

# Backend
SERVER_PORT=8081
DB_URL=jdbc:mysql://localhost:3306/oa_management?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=oa_user
DB_PASSWORD=change-me
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=oa_user
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/
OA_JWT_SECRET=replace-with-at-least-32-random-characters
OA_FILE_UPLOAD_PATH=./upload

# Scheduled tasks
OA_TASKS_ZONE=Asia/Shanghai
OA_TASKS_POOL_SIZE=4
OA_SCHEDULE_REMINDER_CRON="0 * * * * ?"
OA_SCHEDULE_LIFECYCLE_CRON="0 */5 * * * ?"
OA_APPROVAL_OVERDUE_ENABLED=true
OA_APPROVAL_OVERDUE_CRON="0 0 9 * * MON-FRI"
OA_APPROVAL_OVERDUE_HOURS=24
OA_APPROVAL_OVERDUE_BATCH_SIZE=200

# Mail (never commit real credentials)
OA_MAIL_HOST=smtp.qq.com
OA_MAIL_PORT=587
OA_MAIL_USERNAME=
OA_MAIL_PASSWORD=
OA_MAIL_TEST_RECIPIENT=

# AI (never commit real credentials)
OA_AI_PROVIDER=mock
DASHSCOPE_API_KEY=
TONGYI_API_KEY=
